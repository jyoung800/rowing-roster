# Copy this to ".env" and fill in your values before running server.py

# ── Roller API credentials ──────────────────────────────────────────────
# Get these from Roller Venue Manager → Settings → Integrations → API Keys
# (create the key for the Data API, not the REST/booking API)
ROLLER_CLIENT_ID=your_client_id_here
ROLLER_CLIENT_SECRET=your_client_secret_here
ROLLER_VENUE_ID=your_venue_id_here

# ── Demo mode ────────────────────────────────────────────────────────────
# Set to true to return sample data instead of calling Roller (no credentials needed)
DEMO_MODE=false

# ── PLU filtering ───────────────────────────────────────────────────────
# Comma-separated list of PLU numbers for your rowing membership products.
# Only members who bought a product with one of these PLUs will appear.
# Leave blank to show ALL membership products.
MEMBERSHIP_PLUS=8565,8572,8573,8574,8575,8579,9528,9529,9530,9531,9547,9548,9549,9550

# ── Port (optional) ─────────────────────────────────────────────────────
# PORT=5050
